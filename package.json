{
  "name": "chatgpt-desktop",
  "version": "1.1.0",
  "description": "Minimal Electron wrapper for ChatGPT with optional customization, optimized for Linux",
  "homepage": "https://chatgpt.com",
  "main": "main.js",
  "author": {
    "name": "alter.daemon",
    "email": "alter.daemon.ivytq@passmail.com"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:linux": "electron-builder --linux --publish never",
    "release:linux": "npm run build:linux"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.alterdaemon.chatgpt-desktop",
    "productName": "ChatGPT Desktop (Unofficial)",
    "npmRebuild": false,
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "build/icons/icon.png"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${name}_${version}_${arch}.${ext}",
      "icon": "build/icons",
      "executableName": "chatgpt-desktop",
      "maintainer": "alter.daemon <alter.daemon.ivytq@passmail.com>",
      "category": "Utility"
    }
  }
}
